# ============================================================
# PRODUCTION ENVIRONMENT VARIABLES (Heroku Config Vars)
# ============================================================
# Copy these to: heroku config:set KEY=VALUE --app YOUR_APP_NAME
# Or set via: https://dashboard.heroku.com → App → Settings → Config Vars

# ---- Auto-set by Heroku Postgres Add-on ----
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ---- Required: Generate a strong random secret ----
JWT_SECRET="replace-with-long-random-secret-minimum-32-chars"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="replace-with-another-long-random-secret"

# ---- Server ----
NODE_ENV="production"
PORT=3000
API_PREFIX="/api"

# ---- CORS: Set to your deployed frontend URL ----
FRONTEND_URL="https://your-frontend.vercel.app"

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000

# ---- Cache ----
CACHE_TTL=300

# ---- File Uploads (Heroku uses ephemeral filesystem — /tmp) ----
UPLOAD_DIR="/tmp/uploads"
MAX_FILE_SIZE=10485760

# ---- NSDC Integration ----
NSDC_API_URL="https://api.nsdc.org.in/v1"
NSDC_API_KEY="your-nsdc-api-key"

# ---- Email (Optional) ----
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="noreply@yourdomain.com"
SMTP_PASS="your-smtp-password"

# ---- AWS S3 (Optional — for persistent file storage) ----
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_REGION="ap-south-1"
AWS_BUCKET_NAME="skill-erp-documents"
