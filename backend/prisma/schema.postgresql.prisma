generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("STUDENT")
  avatar    String?
  isActive  Boolean  @default(true)
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  student   Student?
  trainer   Trainer?
  auditLogs AuditLog[]
}

model Student {
  id             String       @id @default(cuid())
  userId         String       @unique
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentCode    String       @unique
  dob            String?
  gender         String?
  mobile         String?
  address        String?
  aadhaarNumber  String?
  qualification  String?
  skills         String?
  status         String       @default("ACTIVE")
  enrollments    Enrollment[]
  attendances    Attendance[]
  results        Result[]
  feedbacks      Feedback[]
  placements     Placement[]
  documents      Document[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Trainer {
  id             String       @id @default(cuid())
  userId         String       @unique
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainerCode    String       @unique
  qualification  String?
  experience     Int?
  domain         String?
  certifications String?
  skills         String?
  status         String       @default("ACTIVE")
  batches        Batch[]
  sessionLogs    SessionLog[]
  feedbacks      Feedback[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Course {
  id          String     @id @default(cuid())
  name        String
  code        String     @unique
  description String?
  duration    Int
  modules     String?
  certType    String?
  sector      String?
  nsdcCode    String?
  isActive    Boolean    @default(true)
  batches     Batch[]
  materials   Material[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Batch {
  id          String       @id @default(cuid())
  name        String
  courseId    String
  course      Course       @relation(fields: [courseId], references: [id])
  trainerId   String?
  trainer     Trainer?     @relation(fields: [trainerId], references: [id])
  startDate   String
  endDate     String
  status      String       @default("CREATED")
  maxStudents Int          @default(30)
  venue       String?
  nsdcBatchId String?
  enrollments Enrollment[]
  sessions    SessionLog[]
  assessments Assessment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Enrollment {
  id         String   @id @default(cuid())
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id])
  batchId    String
  batch      Batch    @relation(fields: [batchId], references: [id])
  status     String   @default("ACTIVE")
  enrolledAt DateTime @default(now())

  @@unique([studentId, batchId])
}

model SessionLog {
  id          String       @id @default(cuid())
  batchId     String
  batch       Batch        @relation(fields: [batchId], references: [id])
  trainerId   String
  trainer     Trainer      @relation(fields: [trainerId], references: [id])
  date        String
  topic       String
  duration    Float
  notes       String?
  attendances Attendance[]
  createdAt   DateTime     @default(now())
}

model Attendance {
  id        String     @id @default(cuid())
  studentId String
  student   Student    @relation(fields: [studentId], references: [id])
  sessionId String
  session   SessionLog @relation(fields: [sessionId], references: [id])
  status    String     @default("PRESENT")
  remarks   String?
  createdAt DateTime   @default(now())

  @@unique([studentId, sessionId])
}

model Assessment {
  id           String     @id @default(cuid())
  title        String
  batchId      String
  batch        Batch      @relation(fields: [batchId], references: [id])
  type         String     @default("MID")
  totalMarks   Int
  passingMarks Int
  duration     Int
  status       String     @default("SCHEDULED")
  scheduledAt  String
  questions    Question[]
  results      Result[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Question {
  id            String     @id @default(cuid())
  assessmentId  String
  assessment    Assessment @relation(fields: [assessmentId], references: [id])
  question      String
  type          String     @default("MCQ")
  options       String?
  correctAnswer String
  marks         Int        @default(1)
}

model Result {
  id           String     @id @default(cuid())
  studentId    String
  student      Student    @relation(fields: [studentId], references: [id])
  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id])
  score        Int
  totalMarks   Int
  percentage   Float
  isPassed     Boolean
  grade        String?
  submittedAt  DateTime   @default(now())

  @@unique([studentId, assessmentId])
}

model Feedback {
  id            String   @id @default(cuid())
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id])
  trainerId     String
  trainer       Trainer  @relation(fields: [trainerId], references: [id])
  trainerRating Int
  contentRating Int
  infraRating   Int
  overallRating Float
  comment       String?
  batchId       String?
  createdAt     DateTime @default(now())
}

model Company {
  id         String      @id @default(cuid())
  name       String
  industry   String
  hrName     String?
  hrEmail    String?
  hrPhone    String?
  website    String?
  location   String?
  isActive   Boolean     @default(true)
  placements Placement[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Placement {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  type      String   @default("PLACEMENT")
  role      String
  salary    Float?
  startDate String?
  status    String   @default("OFFERED")
  feedback  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Document {
  id         String   @id @default(cuid())
  name       String
  type       String
  url        String
  size       Int?
  mimeType   String?
  studentId  String?
  student    Student? @relation(fields: [studentId], references: [id])
  uploadedBy String
  category   String   @default("OTHER")
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Material {
  id         String   @id @default(cuid())
  title      String
  courseId   String
  course     Course   @relation(fields: [courseId], references: [id])
  type       String
  url        String
  uploadedBy String
  createdAt  DateTime @default(now())
}

model Institution {
  id           String   @id @default(cuid())
  name         String
  code         String   @unique
  address      String?
  state        String?
  district     String?
  pincode      String?
  contactName  String?
  contactEmail String?
  contactPhone String?
  status       String   @default("PENDING")
  mouStatus    String   @default("PENDING")
  nsdcCode     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  module    String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
}
